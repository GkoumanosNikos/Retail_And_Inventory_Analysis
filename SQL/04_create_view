USE retail_toy_sales;

CREATE OR REPLACE VIEW vw_sales_analysis AS
SELECT
    s.sale_id,
    s.date,

    st.store_id,
    st.store_name,
    st.store_city,
    st.store_location,
    st.store_open_date,

    p.product_id,
    p.product_name,
    p.product_category,
    p.product_cost,
    p.product_price,

    s.units,

    i.stock_on_hand

FROM sales s
JOIN stores st
    ON s.store_id = st.store_id
JOIN products p
    ON s.product_id = p.product_id
LEFT JOIN inventory i
    ON s.store_id = i.store_id
   AND s.product_id = i.product_id;
